# TEE Registry CLI Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Network Configuration
# =============================================================================

# RPC endpoint for the OpenGradient network
RPC_URL=http://13.59.43.94:8545

# TEE Registry contract address
TEE_REGISTRY_ADDRESS=0x3d641a2791533b4a0000345ea8d509d01e1ec301

# =============================================================================
# Authentication
# =============================================================================

# Private key for signing transactions (optional)
# If not set, will use unlocked account from node
# WARNING: Never commit this file with a real private key!
TEE_PRIVATE_KEY=

# =============================================================================
# Enclave Configuration
# =============================================================================

# Enclave hostname
ENCLAVE_HOST=

# Enclave port
ENCLAVE_PORT=443

# =============================================================================
# TEE Registration
# =============================================================================

# Payment address for TEE rewards (default: sender address)
PAYMENT_ADDRESS=

# TEE type ID (0=LLMProxy, 1=Validator)
TEE_TYPE=0

# TEE endpoint URL (default: https://ENCLAVE_HOST)
TEE_ENDPOINT=

# =============================================================================
# PCR Configuration
# =============================================================================

# Path to measurements file
MEASUREMENTS_FILE=measurements.txt

# PCR values in hex (alternative to measurements file)
# PCR0=
# PCR1=
# PCR2=

# Version string for PCR approval
PCR_VERSION=v1.0.0

# Previous PCR hash for rotation (optional)
PREVIOUS_PCR=

# Grace period in seconds for PCR rotation
GRACE_PERIOD=0
