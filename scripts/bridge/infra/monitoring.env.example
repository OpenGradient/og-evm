# Bridge metrics exporter configuration.
# OG_EVM_REST_URL is required because the generated Hyperlane artifacts only
# contain the EVM RPC URL, not the Cosmos REST query endpoint.
# BASE_RPC_URL, BASE_TOKEN_ADDRESS, and BASE_COLLATERAL_ROUTER are optional if
# the generated agent/warp artifacts already contain the correct values.

OG_EVM_REST_URL=http://host.docker.internal:1317
BASE_CHAIN_NAME=base
BASE_RPC_URL=
BASE_TOKEN_ADDRESS=
BASE_COLLATERAL_ROUTER=
BRIDGE_METRICS_PORT=9300
BRIDGE_METRICS_TIMEOUT_SECONDS=10
