# Hyperlane validator configuration.
# The validator reads chain metadata and mailbox addresses from the agent config
# JSON referenced by HYPERLANE_AGENT_CONFIG_PATH.

HYPERLANE_AGENT_CONFIG_PATH=./agent-config.json
HYPERLANE_CHAIN_NAME=og-evm
HYPERLANE_VALIDATOR_DB_PATH=./data/validator-db
HYPERLANE_VALIDATOR_SIGNATURES_DIR=./data/validator-signatures
HYPERLANE_VALIDATOR_KEY=REPLACE_WITH_VALIDATOR_PRIVATE_KEY
HYPERLANE_VALIDATOR_METRICS_PORT=9090
HYPERLANE_VALIDATOR_METRICS_PORT=9090
