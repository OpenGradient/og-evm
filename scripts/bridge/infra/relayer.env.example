# Hyperlane relayer configuration.
# The relayer reads chain metadata and contract addresses from the agent config
# JSON referenced by HYPERLANE_AGENT_CONFIG_PATH.

HYPERLANE_AGENT_CONFIG_PATH=./agent-config.json
HYPERLANE_VALIDATOR_SIGNATURES_DIR=./data/validator-signatures
HYPERLANE_RELAYER_DB_PATH=./data/relayer-db
HYPERLANE_RELAY_CHAINS=og-evm,base
HYPERLANE_RELAY_SIGNER_KEY=REPLACE_WITH_RELAYER_PRIVATE_KEY
HYPERLANE_RELAYER_METRICS_PORT=9091
